<?xml version="1.0" encoding="utf-8"?>
<Project>

  <PropertyGroup>
    <!-- Resource (default): used icons are baked into this assembly. Disk: used icons are written to the
         build output as .svg files. The two modes are mutually exclusive. The Disk-mode build wiring lives
         in each pack's .targets (imported after the project body, so it sees the final mode value). -->
    <IconifyBundleMode Condition="'$(IconifyBundleMode)' == ''">Resource</IconifyBundleMode>
  </PropertyGroup>

  <!-- Surface the selected mode to the source generator. -->
  <ItemGroup>
    <CompilerVisibleProperty Include="IconifyBundleMode" />
  </ItemGroup>

  <!-- The generator is injected from the companion .targets (see IconifyBundle.targets); it must be added in
       a target, not here - props evaluate all properties before items, which defeats an add-once guard. -->

</Project>
