@namespace IconifyBundle

@* Renders an IconifyBundle <see cref="Icon"/> as an inline SVG. Extra attributes (class, style,
   aria-*, ...) are splatted onto the root <svg> element. *@

@if (Value.HasBody)
{
    <svg xmlns="http://www.w3.org/2000/svg"
         width="@F(Width ?? Value.Width)"
         height="@F(Height ?? Value.Height)"
         viewBox="@($"0 0 {F(Value.Width)} {F(Value.Height)}")"
         @attributes="AdditionalAttributes">@((MarkupString)Value.Body)</svg>
}

@code {

    // SVG numbers are always '.'-decimal and culture-independent.
    static string F(double value) => value.ToString(System.Globalization.CultureInfo.InvariantCulture);

    /// <summary>The icon to render, e.g. <c>Feather.Activity</c>.</summary>
    [Parameter]
    public Icon Value { get; set; }

    /// <summary>Optional rendered width (defaults to the icon's intrinsic width).</summary>
    [Parameter]
    public int? Width { get; set; }

    /// <summary>Optional rendered height (defaults to the icon's intrinsic height).</summary>
    [Parameter]
    public int? Height { get; set; }

    /// <summary>Additional attributes (class, style, aria-*, ...) splatted onto the &lt;svg&gt;.</summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

}
