<?xml version="1.0" encoding="utf-8"?>
<Project>

  <PropertyGroup>
    <Version>1.0.0</Version>
    <AssemblyVersion>1.0.0</AssemblyVersion>
    <FileVersion>1.0.0</FileVersion>
    <LangVersion>preview</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <Deterministic>true</Deterministic>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <SuppressNETCoreSdkPreviewMessage>true</SuppressNETCoreSdkPreviewMessage>
    <ResolveAssemblyReferencesSilent>true</ResolveAssemblyReferencesSilent>
    <!-- IDE0005: global usings from ProjectDefaults are unused in some small projects;
         with TreatWarningsAsErrors that would fail the build, so suppress it. -->
    <NoWarn>$(NoWarn);CS1591;NU1608;NU1109;IDE0005</NoWarn>
  </PropertyGroup>

  <!-- Shared NuGet package metadata -->
  <PropertyGroup>
    <Authors>Simon Cropp</Authors>
    <Company>Simon Cropp</Company>
    <Copyright>Copyright (c) Simon Cropp</Copyright>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/SimonCropp/Iconistic</PackageProjectUrl>
    <RepositoryUrl>https://github.com/SimonCropp/Iconistic</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>iconify;icons;svg;source-generator;blazor</PackageTags>
    <PackageOutputPath>$(MSBuildThisFileDirectory)..\nugets</PackageOutputPath>
  </PropertyGroup>

</Project>
