@namespace Iconistic

@* Renders an Iconistic <see cref="Icon"/> as an inline SVG. Extra attributes (class, style,
   aria-*, ...) are splatted onto the root <svg> element. *@

@if (Value.Body is not null)
{
    <svg xmlns="http://www.w3.org/2000/svg"
         width="@(Width ?? Value.Width)"
         height="@(Height ?? Value.Height)"
         viewBox="@($"0 0 {Value.Width} {Value.Height}")"
         @attributes="AdditionalAttributes">@((MarkupString)Value.Body)</svg>
}

@code {

    /// <summary>The icon to render, e.g. <c>Feather.Activity</c>.</summary>
    [Parameter]
    public Icon Value { get; set; }

    /// <summary>Optional rendered width (defaults to the icon's intrinsic width).</summary>
    [Parameter]
    public int? Width { get; set; }

    /// <summary>Optional rendered height (defaults to the icon's intrinsic height).</summary>
    [Parameter]
    public int? Height { get; set; }

    /// <summary>Additional attributes (class, style, aria-*, ...) splatted onto the &lt;svg&gt;.</summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

}
