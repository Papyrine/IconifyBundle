@namespace Iconistic.Web

<header>
    <h1>Iconistic</h1>
    <p>Strongly-typed <a href="https://iconify.design/">Iconify</a> icons. Below is the Feather pack,
       rendered via the generated API and the <code>&lt;Iconify&gt;</code> component.</p>
</header>

<main>
    <div class="grid">
        @foreach (var (name, icon) in Icons)
        {
            <figure class="cell" title="@name">
                <Iconify Value="icon" Width="32" Height="32" />
                <figcaption>@name</figcaption>
            </figure>
        }
    </div>
</main>

