<Project>

  <Import Project="..\Version.props" />

  <PropertyGroup>
    <ManagePackageVersionsCentrally>true</ManagePackageVersionsCentrally>
  </PropertyGroup>

  <ItemGroup>
    <PackageVersion Include="TUnit" Version="1.45.22" />
    <PackageVersion Include="Iconistic" Version="$(IconisticVersion)" />
    <PackageVersion Include="Iconistic.Feather" Version="$(IconisticVersion)" />
  </ItemGroup>

</Project>
