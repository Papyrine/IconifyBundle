<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <OutputType>Exe</OutputType>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <!-- Disk mode: pack SVG files are copied to the build output and file-path members are generated. -->
    <IconisticMode>Disk</IconisticMode>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="TUnit" />
    <PackageReference Include="Iconistic" />
    <PackageReference Include="Iconistic.Feather" />
  </ItemGroup>

</Project>
