<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <!-- IconifyBundle + IconifyBundle.Blazor land in nugets/, the IconifyBundle.<Pack> nupkgs land in packs/.
         Both feeds are required so the consumer projects below can resolve their freshly-built dependencies
         (without relying on the previously-published version still being on nuget.org). -->
    <add key="local-runtime" value="../nugets" />
    <add key="local-packs" value="../packs" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
